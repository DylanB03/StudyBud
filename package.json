{
  "name": "studybud",
  "productName": "StudyBud",
  "version": "1.0.0",
  "description": "AI-powered desktop study workspace for lecture and homework PDFs",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "prepare:ocr-runtime": "node scripts/prepare-ocr-runtime.mjs",
    "build:ocr:win": "node scripts/build-ocr-runtime-win.mjs",
    "rebuild:native:node": "npm rebuild better-sqlite3",
    "rebuild:native:electron": "electron-rebuild -f -w better-sqlite3",
    "start": "npm run rebuild:native:electron && electron-forge start",
    "dev": "npm run rebuild:native:electron && electron-forge start",
    "package": "npm run prepare:ocr-runtime && npm run rebuild:native:electron && electron-forge package",
    "make": "npm run prepare:ocr-runtime && npm run rebuild:native:electron && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:check-native": "node scripts/check-better-sqlite3-node.cjs",
    "test:prepared": "npm run test:check-native && npm run test",
    "verify": "npm run typecheck && npm run lint && npm run test:prepared && npm run package"
  },
  "keywords": [],
  "author": {
    "name": "DylanB03",
    "email": "dylanbutz@hotmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "electron": "41.1.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^27.0.1",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-squirrel-startup": "^1.0.1",
    "katex": "^0.16.45",
    "material-symbols": "^0.44.2",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
